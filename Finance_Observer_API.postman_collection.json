        {
          "name": "Test - Verify All Alerts Created",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "List all created alerts. Check for:\n- Both price and candle_close alert types\n- Active status before trigger\n- Different channels (email, sms, call)\n- Correct pair/interval/threshold values"
