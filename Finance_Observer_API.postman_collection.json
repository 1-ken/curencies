{
  "info": {
    "name": "Finance Observer API",
    "description": "Real-time forex currency pair price monitoring with price alerts",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "api_base",
      "value": "{{base_url}}/api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Data & Streaming",
      "description": "Endpoints for real-time forex data",
      "item": [
        {
          "name": "Get Current Snapshot",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/snapshot",
              "host": ["{{base_url}}"],
              "path": ["snapshot"]
            },
            "description": "Get a single snapshot of current forex data"
          },
          "response": []
        },
        {
          "name": "Get Client Config",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/client-config",
              "host": ["{{base_url}}"],
              "path": ["client-config"]
            },
            "description": "Get client runtime configuration (WebSocket URL, etc.)"
          },
          "response": []
        },
        {
          "name": "Query Historical Data",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/historical?pair=EURUSD&start=2026-03-18T00:00:00Z&end=2026-03-18T23:59:59Z&limit=500&order=desc",
              "host": ["{{base_url}}"],
              "path": ["historical"],
              "query": [
                {
                  "key": "pair",
                  "value": "EURUSD",
                  "disabled": true,
                  "description": "Optional: filter by currency pair (e.g., EURUSD or EUR/USD)"
                },
                {
                  "key": "start",
                  "value": "2026-03-18T00:00:00Z",
                  "disabled": true,
                  "description": "Optional: start date-time (ISO 8601)"
                },
                {
                  "key": "end",
                  "value": "2026-03-18T23:59:59Z",
                  "disabled": true,
                  "description": "Optional: end date-time (ISO 8601)"
                },
                {
                  "key": "limit",
                  "value": "500",
                  "description": "Max results (1-5000, default 500)"
                },
                {
                  "key": "order",
                  "value": "desc",
                  "description": "Sort order: 'desc' (default) or 'asc'"
                }
              ]
            },
            "description": "Query historical data stored in PostgreSQL (responses are limited to the most recent 14 days)."
          },
          "response": []
        },
        {
          "name": "Query Historical Stream Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/historical/stream-metrics?start=2026-03-18T00:00:00Z&end=2026-03-20T23:59:59Z&limit=500&order=desc",
              "host": ["{{base_url}}"],
              "path": ["historical", "stream-metrics"],
              "query": [
                {
                  "key": "start",
                  "value": "2026-03-18T00:00:00Z",
                  "disabled": true,
                  "description": "Optional: start date-time (ISO 8601). Values older than 14 days are clamped."
                },
                {
                  "key": "end",
                  "value": "2026-03-20T23:59:59Z",
                  "disabled": true,
                  "description": "Optional: end date-time (ISO 8601)"
                },
                {
                  "key": "limit",
                  "value": "500",
                  "description": "Max results (1-5000, default 1000)"
                },
                {
                  "key": "order",
                  "value": "desc",
                  "description": "Sort order: 'desc' (default) or 'asc'"
                }
              ]
            },
            "description": "Query persisted stream metrics (subscriber counts, snapshot failures, and stream status). Responses are limited to the most recent 14 days."
          },
          "response": []
        },
        {
          "name": "Query OHLC Candlesticks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/historical/ohlc?pair=EURUSD&interval=5m&start=2026-02-18T00:00:00Z&limit=100",
              "host": ["{{base_url}}"],
              "path": ["historical", "ohlc"],
              "query": [
                {
                  "key": "pair",
                  "value": "EURUSD",
                  "description": "Required: currency pair (supports EURUSD or EUR/USD format)"
                },
                {
                  "key": "interval",
                  "value": "5m",
                  "description": "Time interval: 1m, 5m, 15m, 30m, 1h, 4h, 1d (default: 5m)"
                },
                {
                  "key": "start",
                  "value": "2026-02-18T00:00:00Z",
                  "disabled": true,
                  "description": "Optional: start date-time (ISO 8601)"
                },
                {
                  "key": "end",
                  "value": "2026-02-18T23:59:59Z",
                  "disabled": true,
                  "description": "Optional: end date-time (ISO 8601)"
                },
                {
                  "key": "limit",
                  "value": "100",
                  "description": "Max candles (1-5000, default 1000)"
                }
              ]
            },
            "description": "Get OHLC candlestick data aggregated by time interval (5m, 1h, 1d, etc.). Pair supports both slash and non-slash formats (e.g., EURUSD or EUR/USD)."
          },
          "response": []
        },
        {
          "name": "WebSocket Real-time Stream",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Connection",
                "value": "Upgrade"
              },
              {
                "key": "Upgrade",
                "value": "websocket"
              },
              {
                "key": "Sec-WebSocket-Version",
                "value": "13"
              },
              {
                "key": "Sec-WebSocket-Key",
                "value": "SGVsbG8sIHdvcmxkIQ=="
              }
            ],
            "url": {
              "raw": "{{base_url}}/ws/observe",
              "host": ["{{base_url}}"],
              "path": ["ws/observe"]
            },
            "description": "WebSocket endpoint for streaming real-time forex data and alerts. Connect with a WebSocket client to receive live updates."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Alerts API",
      "description": "Endpoints for managing price alerts and candle-close threshold alerts",
      "item": [
        {
          "name": "Get All Alerts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "Retrieve all alerts (active, triggered, and all)"
          },
          "response": []
        },
        {
          "name": "Create Price Alert (Email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair\": \"EURUSD\",\n  \"target_price\": 1.0850,\n  \"condition\": \"above\",\n  \"channel\": \"email\",\n  \"email\": \"user@example.com\",\n  \"phone\": \"\",\n  \"custom_message\": \"EUR/USD reached important level\",\n  \"alert_type\": \"price\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "Create a new price alert (live-based). Triggers when current snapshot price meets condition."
          },
          "response": []
        },
        {
          "name": "Create Price Alert (SMS)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair\": \"GBPUSD\",\n  \"target_price\": 1.2700,\n  \"condition\": \"below\",\n  \"channel\": \"sms\",\n  \"email\": \"\",\n  \"phone\": \"+1234567890\",\n  \"custom_message\": \"GBP/USD dropped below target\",\n  \"alert_type\": \"price\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "Create an SMS price alert (requires AFRICASTALKING credentials)"
          },
          "response": []
        },
        {
          "name": "Create Price Alert (Call)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair\": \"EURUSD\",\n  \"target_price\": 1.0900,\n  \"condition\": \"above\",\n  \"channel\": \"call\",\n  \"email\": \"\",\n  \"phone\": \"+1234567890\",\n  \"custom_message\": \"EUR/USD hit your target\",\n  \"alert_type\": \"price\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "Create a call price alert (requires Twilio credentials)"
          },
          "response": []
        },
        {
          "name": "Create Candle-Close Alert (Above, Email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair\": \"EURUSD\",\n  \"interval\": \"15m\",\n  \"direction\": \"above\",\n  \"threshold\": 1.0850,\n  \"channel\": \"email\",\n  \"email\": \"user@example.com\",\n  \"phone\": \"\",\n  \"custom_message\": \"15m candle closed above 1.0850\",\n  \"alert_type\": \"candle_close\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "Create a candle-close threshold alert (email). Triggers when a fully closed candle's close price is above the threshold. Checked every 30 seconds against PostgreSQL OHLC data."
          },
          "response": []
        },
        {
          "name": "Create Candle-Close Alert (Below, Email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair\": \"GBPUSD\",\n  \"interval\": \"5m\",\n  \"direction\": \"below\",\n  \"threshold\": 1.2500,\n  \"channel\": \"email\",\n  \"email\": \"trader@example.com\",\n  \"phone\": \"\",\n  \"custom_message\": \"5m candle closed below 1.2500\",\n  \"alert_type\": \"candle_close\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "Create a candle-close alert (below threshold). Triggers only once per candle when close <= threshold."
          },
          "response": []
        },
        {
          "name": "Create Candle-Close Alert (Above, SMS)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair\": \"USDJPY\",\n  \"interval\": \"1h\",\n  \"direction\": \"above\",\n  \"threshold\": 150.00,\n  \"channel\": \"sms\",\n  \"email\": \"\",\n  \"phone\": \"+1234567890\",\n  \"custom_message\": \"1h candle above 150.00\",\n  \"alert_type\": \"candle_close\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "Create a candle-close SMS alert. Supported intervals: 1m, 5m, 15m, 30m, 1h, 4h, 1d"
          },
          "response": []
        },
        {
          "name": "Create Candle-Close Alert (Below, Call)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair\": \"AUDUSD\",\n  \"interval\": \"30m\",\n  \"direction\": \"below\",\n  \"threshold\": 0.6700,\n  \"channel\": \"call\",\n  \"email\": \"\",\n  \"phone\": \"+1234567890\",\n  \"custom_message\": \"30m candle below 0.6700\",\n  \"alert_type\": \"candle_close\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/alerts",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts"]
            },
            "description": "Create a candle-close call alert. One-shot trigger per candle (won't repeat for same candle)."
          },
          "response": []
        },
        {
          "name": "Get Specific Alert",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base}}/alerts/{{alert_id}}",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts", "{{alert_id}}"]
            },
            "description": "Get details of a specific alert by ID. Returns both price and candle-close alert types."
          },
          "response": []
        },
        {
          "name": "Delete Alert",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_base}}/alerts/{{alert_id}}",
              "host": ["{{base_url}}", "api", "v1"],
              "path": ["alerts", "{{alert_id}}"]
            },
            "description": "Delete an alert by ID (works for all alert types)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Examples & Test Scenarios",
      "description": "Example requests and common test scenarios for both price and candle-close alerts",
      "item": [
        {
          "name": "Test Workflow - Price Alert",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/snapshot",
              "host": ["{{base_url}}"],
              "path": ["snapshot"]
            },
            "description": "WORKFLOW: Price Alert\n1. Get current snapshot to see available pairs and prices\n2. Create a price alert above/below current price\n3. Monitor via WebSocket for real-time updates (triggers on live data)\n4. Query alerts to see trigger status"
          },
          "response": []
        },
        {
          "name": "Test Workflow - Candle-Close Alert",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/historical/ohlc?pair=EURUSD&interval=15m&limit=5",
              "host": ["{{base_url}}"],
              "path": ["historical", "ohlc"],
              "query": [
                {
                  "key": "pair",
                  "value": "EURUSD"
                },
                {
                  "key": "interval",
                  "value": "15m"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "WORKFLOW: Candle-Close Alert\n1. Query OHLC data to see recent candle closes and prices\n2. Create a candle-close alert at a specific threshold\n3. Monitoring loop checks every 30 seconds for fully closed candles\n4. Alert triggers only once when matching candle close is detected\n5. Check alerts to confirm trigger status and evaluation timestamp"
          },
          "response": []
        },
        {
          "name": "Test - Query OHLC 1m (EUR/USD Format)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/historical/ohlc?pair=EUR%2FUSD&interval=1m&limit=10",
              "host": ["{{base_url}}"],
              "path": ["historical", "ohlc"],
              "query": [
                {
                  "key": "pair",
                  "value": "EUR/USD"
                },
                {
                  "key": "interval",
                  "value": "1m"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Verify slash-format pair support by querying 1m OHLC with EUR/USD."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Response contains candles array', function () {",
                  "  pm.expect(json).to.have.property('candles');",
                  "  pm.expect(json.candles).to.be.an('array');",
                  "});",
                  "pm.test('At least one 1m candle returned', function () {",
                  "  pm.expect(json.count).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Test - Create Candle Alert Above & Monitor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair\": \"EURUSD\",\n  \"interval\": \"15m\",\n  \"direction\": \"above\",\n  \"threshold\": 1.0850,\n  \"channel\": \"email\",\n  \"email\": \"test@example.com\",\n  \"custom_message\": \"Test: 15m candle closed above 1.0850\",\n  \"alert_type\": \"candle_close\"\n}"
