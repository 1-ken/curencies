        },
        {
          "name": "Test - Different Intervals (1h, 4h, 1d)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/historical/ohlc?pair=EURUSD&interval=1h&limit=20",
              "host": ["{{base_url}}"],
              "path": ["historical", "ohlc"],
              "query": [
                {
                  "key": "pair",
                  "value": "EURUSD"
                },
                {
                  "key": "interval",
                  "value": "1h"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
